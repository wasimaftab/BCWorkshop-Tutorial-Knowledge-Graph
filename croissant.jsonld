  "hasPart": {
    "@type": "sc:Dataset",
    "name": "Synthetic Protein Interaction Dataset",
    "description": "Synthetic tab-separated protein-protein interaction data used by the BioCypher workshop tutorial knowledge graph. The dataset contains source and target protein identifiers, gene symbols, taxonomy identifiers, interaction type labels, and boolean interaction evidence flags. Matching field descriptions are complemented from the networks data dictionary.",
    "conformsTo": "http://mlcommons.org/croissant/1.1",
    "citeAs": "https://doi.org/10.5281/zenodo.16902349",
    "creator": {
      "@type": "sc:Person",
      "name": "Edwin Carreno",
      "url": "https://orcid.org/0009-0005-3359-2211"
    },
    "datePublished": "2025-08-05",
    "keywords": [
      "synthetic data",
      "protein interactions",
      "BioCypher",
      "knowledge graph",
      "TSV"
    ],
    "license": "https://opensource.org/licenses/MIT",
    "url": "https://zenodo.org/records/16902349",
    "version": "1.0.1",
