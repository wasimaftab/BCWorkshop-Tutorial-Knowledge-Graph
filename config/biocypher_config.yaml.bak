#-------------------------------------------------------------------
#-----------------       BIOCYPHER SETTINGS        -----------------
#-------------------------------------------------------------------
biocypher:
  dbms: neo4j
  offline: true
  schema_config_path: config/schema_config.yaml
  strict_mode: false
  head_ontology:
    url: https://github.com/biolink/biolink-model/raw/v3.2.1/biolink-model.owl.ttl
    root_node: entity
    switch_label_and_id: true
  debug: false
  cache_directory: .cache
  output_directory: biocypher-out
  log_directory: biocypher-log

#-------------------------------------------------------------------
#-----------------       OUTPUT Configuration      -----------------
#-------------------------------------------------------------------
#---- NEO4J database management system
neo4j:
  database_name: neo4j
  delimiter: "\t"
  array_delimiter: ";"
  quote_character: '"'
  skip_duplicate_nodes: true
  skip_bad_relationships: true

  # ── TODO 1 ───────────────────────────────────────────────────────────────
  # Task: Set the path to your Neo4j instance binary folder.
  # Why:  BioCypher needs this to locate neo4j-admin and generate the correct
  #       import command for your machine.
  # Hint: Open Neo4j Desktop → Overview tab → copy the instance path shown
  #       (e.g. /home/user/neo4j-instance/) and append /bin/ to it.
  # ────────────────────────────────────────────────────────────────────────
  # ---------- YOUR CODE STARTS HERE ----------
  import_call_bin_prefix: /home/wasim/.config/neo4j-desktop/Application/Data/dbmss/dbms-7b86e292-488a-4cde-9558-e3a5347f24fc/bin/
  # ---------- YOUR CODE ENDS HERE ----------
